---
import '../styles/global.css';

interface Props {
  title: string;
  activeTab?: string;
}

const { title } = Astro.props;
const p = Astro.url.pathname;

const nav = [
  { href: '/',         label: '대시보드' },
  { href: '/dashboard', label: '자비스' },
  { href: '/archive',  label: '아카이브' },
  { href: '/insights', label: '인사이트' },
  { href: '/quotes',   label: '좋은글'   },
  { href: '/videos',   label: '유튜브'   },
  { href: '/gallery',  label: '갤러리'   },
  { href: '/analysis', label: '독서'     },
  { href: '/team',     label: '팀'       },
];

function active(href: string) {
  if (href === '/') return p === '/';
  return p.startsWith(href);
}
---

<html lang="ko">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width" />
  <title>{title} — Comind Works</title>
</head>
<body class="h-screen flex flex-col overflow-hidden" style="background:#0d0d0f; color:#e2e8f0; font-family:'Pretendard',-apple-system,sans-serif;">

  <!-- 토크바 -->
  <header style="height:40px; border-bottom:1px solid rgba(255,255,255,0.06); display:flex; align-items:center; padding:0 16px; gap:8px; background:#0d0d0f; flex-shrink:0; position:sticky; top:0; z-index:50;">
    <a href="/" style="font-size:13px; font-weight:800; letter-spacing:-0.03em; color:#fff; text-decoration:none; margin-right:4px;">
      Comind<span style="color:#818cf8;">Works</span>
    </a>
    <div style="width:1px; height:14px; background:rgba(255,255,255,0.08); margin:0 4px;"></div>
    <nav style="display:flex; gap:2px;">
      {nav.map(link => (
        <a href={link.href} style={active(link.href)
          ? 'height:28px; padding:0 10px; display:flex; align-items:center; gap:5px; font-size:12px; font-weight:600; color:#fff; background:rgba(255,255,255,0.09); border-radius:6px; text-decoration:none;'
          : 'height:28px; padding:0 10px; display:flex; align-items:center; gap:5px; font-size:12px; font-weight:400; color:rgba(255,255,255,0.38); border-radius:6px; text-decoration:none; transition:color 0.15s, background 0.15s;'}
          onmouseover={!active(link.href) ? "this.style.color='rgba(255,255,255,0.7)';this.style.background='rgba(255,255,255,0.05)';" : ''}
          onmouseout={!active(link.href) ? "this.style.color='rgba(255,255,255,0.38)';this.style.background='transparent';" : ''}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </header>

  <!-- 바디 -->
  <div style="display:flex; flex:1; min-height:0; overflow:hidden;">

    <!-- 사이드바 -->
    <aside style="width:200px; flex-shrink:0; border-right:1px solid rgba(255,255,255,0.06); display:flex; flex-direction:column; overflow-y:auto; padding:8px 0;">
      <slot name="sidebar" />
    </aside>

    <!-- 콘텐츠 -->
    <main style="flex:1; min-width:0; overflow-y:auto; padding:24px 28px;">
      <slot />
    </main>

  </div>

</body>
</html>
