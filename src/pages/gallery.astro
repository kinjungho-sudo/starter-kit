---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('gallery');
const filterType = Astro.url.searchParams.get('type') ?? '';
const types = [...new Set(all.map((i:any) => i.data.type).filter(Boolean))];
const filtered = filterType ? all.filter((i:any) => i.data.type === filterType) : all;

const typeLabel: Record<string, string> = {
  vanilla: 'Vanilla HTML',
  ppt: 'PPT',
  external: '외부 링크',
};
---

<Layout title="갤러리">

  <div slot="sidebar">
    <p class="sb-label">전체</p>
    <a href="/gallery" class={`sb-item${!filterType ? ' active' : ''}`}>
      모든 결과물
      <span class="count">{all.length}</span>
    </a>

    {types.length > 0 && (
      <>
        <hr class="sb-divider" />
        <p class="sb-label">타입</p>
        {types.map((t: any) => (
          <a href={`/gallery?type=${encodeURIComponent(t)}`} class={`sb-item${filterType === t ? ' active' : ''}`}>
            {typeLabel[t] ?? t}
            <span class="count">{all.filter((i:any) => i.data.type === t).length}</span>
          </a>
        ))}
      </>
    )}
  </div>

  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div>
      <h1 class="page-title">{filterType ? (typeLabel[filterType] ?? filterType) : '갤러리'}</h1>
      <p class="page-meta">결과물 {filtered.length}건</p>
    </div>
  </div>

  {filtered.length === 0 ? (
    <div style="padding:64px 0; text-align:center; color:var(--muted2); font-size:13px;">아직 등록된 결과물이 없습니다.</div>
  ) : (
    <div class="gallery-grid">
      {filtered.map((item:any) => {
        const hasPreview = item.data.link && (item.data.type === 'vanilla' || item.data.type === 'ppt' || item.data.type === 'external');
        return (
          <a href={`/gallery/${item.id}`} class="gallery-card">
            <!-- 미리보기 영역 -->
            <div class="gallery-preview">
              {hasPreview ? (
                <iframe
                  src={item.data.link}
                  title={item.data.title ?? item.id}
                  loading="lazy"
                  sandbox="allow-scripts allow-same-origin allow-forms"
                  scrolling="no"
                  tabindex="-1"
                  aria-hidden="true"
                ></iframe>
              ) : (
                <div class="gallery-preview-empty">
                  <span>{item.data.title?.[0] ?? '?'}</span>
                </div>
              )}
              <div class="gallery-preview-overlay"></div>
            </div>

            <!-- 카드 정보 -->
            <div class="gallery-info">
              <div style="display:flex; align-items:center; gap:6px; flex-wrap:wrap; margin-bottom:6px;">
                {item.data.type && (
                  <span class="gallery-type-badge">{typeLabel[item.data.type] ?? item.data.type}</span>
                )}
                {item.data.created && (
                  <span style="font-size:10px; color:rgba(255,255,255,0.3);">{item.data.created}</span>
                )}
              </div>
              <p class="gallery-title">{item.data.title ?? item.id}</p>
              {item.data.description && (
                <p class="gallery-desc">{item.data.description}</p>
              )}
              {item.data.maker && (
                <p style="font-size:10px; color:rgba(255,255,255,0.3); margin-top:4px;">by {item.data.maker}</p>
              )}
              <!-- 에이전트/스킬/기능 -->
              {(item.data.agents?.length || item.data.skills?.length || item.data.features?.length) && (
                <div class="gallery-tech">
                  {item.data.agents?.map((a: string) => (
                    <span class="tech-badge agent">{a}</span>
                  ))}
                  {item.data.skills?.map((s: string) => (
                    <span class="tech-badge skill">{s}</span>
                  ))}
                  {item.data.features?.map((f: string) => (
                    <span class="tech-badge feature">{f}</span>
                  ))}
                </div>
              )}
            </div>
          </a>
        );
      })}
    </div>
  )}

</Layout>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 12px;
  }

  .gallery-card {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    background: rgba(255,255,255,0.02);
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s;
  }
  .gallery-card:hover {
    border-color: rgba(129,140,248,0.4);
    transform: translateY(-2px);
  }

  .gallery-preview {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: #111;
  }
  .gallery-preview iframe {
    position: absolute;
    top: 0; left: 0;
    width: 200%;
    height: 200%;
    transform: scale(0.5);
    transform-origin: top left;
    border: none;
    pointer-events: none;
  }
  .gallery-preview-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(13,13,15,0.8));
  }
  .gallery-preview-empty {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1e1b4b, #0d0d0f);
    font-size: 32px;
    font-weight: 900;
    color: rgba(255,255,255,0.1);
  }

  .gallery-info {
    padding: 12px 14px 14px;
  }
  .gallery-type-badge {
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 4px;
    background: rgba(129,140,248,0.15);
    color: #818cf8;
    border: 1px solid rgba(129,140,248,0.25);
  }
  .gallery-title {
    font-size: 13px;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
    line-height: 1.4;
    margin: 0;
  }
  .gallery-desc {
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    line-height: 1.5;
    margin-top: 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .gallery-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 8px;
  }
  .tech-badge {
    font-size: 9px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid;
  }
  .tech-badge.agent {
    background: rgba(16,185,129,0.1);
    color: #34d399;
    border-color: rgba(16,185,129,0.25);
  }
  .tech-badge.skill {
    background: rgba(245,158,11,0.1);
    color: #fbbf24;
    border-color: rgba(245,158,11,0.25);
  }
  .tech-badge.feature {
    background: rgba(99,102,241,0.1);
    color: #a5b4fc;
    border-color: rgba(99,102,241,0.25);
  }
</style>
