---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allGallery = await getCollection('gallery');
const sorted = allGallery.sort((a, b) => (b.data.week ?? 0) - (a.data.week ?? 0));
---

<Layout title="갤러리">
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12">
        <div class="text-xs font-black uppercase tracking-widest text-indigo-400 mb-3">GALLERY</div>
        <h1 class="text-3xl font-black text-white mb-3">결과물 갤러리</h1>
        <p class="text-white/50">멤버들이 실제로 만들어 배포한 결과물 모음입니다.</p>
      </div>

      {sorted.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-white/30 text-sm mb-2">아직 등록된 결과물이 없습니다.</p>
          <p class="text-white/20 text-xs">
            <code class="bg-white/10 px-2 py-0.5 rounded">01_gallery/</code> 폴더에 마크다운 파일을 추가하면 자동 반영됩니다.
          </p>
        </div>
      ) : (
        <div class="grid md:grid-cols-2 gap-5">
          {sorted.map(project => (
            <a
              href={project.data.link ?? '#'}
              target={project.data.link ? '_blank' : undefined}
              rel="noopener noreferrer"
              class="group block bg-white/[0.04] border border-white/10 hover:border-indigo-400/40 rounded-2xl p-6 transition-all"
            >
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-bold text-indigo-400">
                  {project.data.maker}{project.data.week ? ` · Week ${project.data.week}` : ''}
                </span>
                {project.data.link && (
                  <span class="text-xs text-white/30 group-hover:text-indigo-400 transition-colors">↗</span>
                )}
              </div>
              <h3 class="font-bold text-white text-base mb-2 group-hover:text-indigo-200 transition-colors">
                {project.data.title}
              </h3>
              {project.data.description && (
                <p class="text-sm text-white/50 mb-4 leading-relaxed">{project.data.description}</p>
              )}
              <div class="flex flex-wrap gap-1.5">
                {(project.data.tags ?? []).map((tag: string) => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-white/[0.06] text-white/60 border border-white/10">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      )}

      <div class="mt-12 text-center text-white/30 text-sm">
        결과물은 <code class="text-white/50 bg-white/10 px-2 py-0.5 rounded">01_gallery/</code> 폴더에 등록하면 자동 반영됩니다.
      </div>
    </div>
  </section>
</Layout>
