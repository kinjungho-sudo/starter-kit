---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allMissions = await getCollection('missions');

// 주차별 그룹핑
const byWeek = allMissions.reduce((acc, m) => {
  const w = m.data.week;
  if (!acc[w]) acc[w] = [];
  acc[w].push(m);
  return acc;
}, {} as Record<number, typeof allMissions>);

const weeks = Object.keys(byWeek)
  .map(Number)
  .sort((a, b) => b - a); // 최신 주차 먼저
---

<Layout title="아카이브">
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12">
        <div class="text-xs font-black uppercase tracking-widest text-indigo-400 mb-3">ARCHIVE</div>
        <h1 class="text-3xl font-black text-white mb-3">주차별 과제 아카이브</h1>
        <p class="text-white/50">멤버들이 매주 만든 결과물과 인사이트를 모두 기록합니다.</p>
      </div>

      {weeks.length === 0 ? (
        <p class="text-white/30 text-sm">아직 제출된 과제가 없습니다.</p>
      ) : (
        <div class="space-y-10">
          {weeks.map(weekNum => (
            <div>
              <div class="flex items-center gap-4 mb-6">
                <a href={`/archive/week-${String(weekNum).padStart(2,'0')}`}
                  class="text-2xl font-black text-white hover:text-indigo-400 transition-colors">
                  Week {weekNum}
                </a>
                <div class="h-px flex-1 bg-white/10"></div>
                <span class="text-xs text-white/30">{byWeek[weekNum].length}명 제출</span>
              </div>

              <div class="grid md:grid-cols-3 gap-4">
                {byWeek[weekNum].map(mission => (
                  <a href={`/archive/week-${String(weekNum).padStart(2,'0')}#${mission.data.member}`}
                    class="group block bg-white/[0.04] hover:bg-white/[0.07] border border-white/10 hover:border-indigo-400/40 rounded-xl p-5 transition-all">
                    <div class="text-xs font-bold text-indigo-400 mb-1">{mission.data.member}</div>
                    <h3 class="text-sm font-bold text-white group-hover:text-indigo-200 transition-colors leading-snug">
                      {mission.data.title}
                    </h3>
                    {(mission.data.stack ?? []).length > 0 && (
                      <div class="flex flex-wrap gap-1 mt-3">
                        {(mission.data.stack ?? []).slice(0, 3).map((s: string) => (
                          <span class="text-xs px-2 py-0.5 rounded-full bg-white/[0.06] text-white/50 border border-white/10">{s}</span>
                        ))}
                      </div>
                    )}
                  </a>
                ))}
              </div>

              <div class="mt-4">
                <a href={`/archive/week-${String(weekNum).padStart(2,'0')}`}
                  class="text-xs text-indigo-400/70 hover:text-indigo-400 transition-colors">
                  Week {weekNum} 전체 보기 →
                </a>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
