---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allMissions = await getCollection('missions');
const byWeek = allMissions.reduce((acc, m) => {
  const w = m.data.week ?? 0;
  if (!acc[w]) acc[w] = [];
  acc[w].push(m);
  return acc;
}, {} as Record<number, typeof allMissions>);
const weeks = Object.keys(byWeek).map(Number).sort((a,b) => b - a);

const urlWeek = Astro.url.searchParams.get('week');
const activeWeek = urlWeek ? Number(urlWeek) : (weeks[0] ?? null);
const current = activeWeek != null ? (byWeek[activeWeek] ?? []) : [];
---

<Layout title="아카이브">

  <div slot="sidebar">
    <p class="sb-label">주차</p>
    {weeks.map(w => (
      <a href={`/archive?week=${w}`} class={`sb-item${w === activeWeek ? ' active' : ''}`}>
        <span class="sb-dot"></span>
        Week {String(w).padStart(2,'0')}
        <span class="count">{byWeek[w].length}</span>
      </a>
    ))}
    {weeks.length === 0 && <p style="padding:4px 12px; font-size:11px; color:var(--muted2)">아직 없음</p>}
  </div>

  {activeWeek != null ? (
    <>
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
        <div>
          <h1 class="page-title">Week {String(activeWeek).padStart(2,'0')}</h1>
          <p class="page-meta">{current.length}명 제출</p>
        </div>
        <span class="badge badge-indigo">아카이브</span>
      </div>

      <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:8px;">
        {current.map(m => (
          <a href={`/archive/${m.id}`} class="card">
            <p class="card-label">{m.data.member ?? m.id}</p>
            <p class="card-title">{m.data.title ?? m.id}</p>
            {m.data.stack && m.data.stack.length > 0 && (
              <div style="display:flex; flex-wrap:wrap; gap:4px; margin-top:8px;">
                {(m.data.stack as string[]).slice(0,3).map(t => (
                  <span class="badge badge-indigo">{t}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    </>
  ) : (
    <div style="padding:64px 0; text-align:center; color:var(--muted2); font-size:13px;">아직 제출된 과제가 없습니다.</div>
  )}

</Layout>
