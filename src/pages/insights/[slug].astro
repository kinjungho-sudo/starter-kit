---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const insights = await getCollection('insights');
  return insights.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <a href="/insights" class="text-xs text-white/40 hover:text-white/70 transition-colors mb-6 inline-block">← 인사이트 목록</a>

      <div class="mb-8">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-xs font-bold text-indigo-400">{entry.data.author}</span>
          {entry.data.week && <span class="text-xs text-white/30">Week {entry.data.week}</span>}
        </div>
        <h1 class="text-2xl md:text-3xl font-black text-white mb-4">{entry.data.title}</h1>
        {entry.data.summary && (
          <p class="text-white/60 leading-relaxed mb-4">{entry.data.summary}</p>
        )}
        <div class="flex flex-wrap gap-2">
          {(entry.data.tags ?? []).map((tag: string) => (
            <span class="text-xs px-2.5 py-0.5 rounded-full bg-white/[0.06] text-white/60 border border-white/10">{tag}</span>
          ))}
        </div>
      </div>

      <div class="border-t border-white/10 pt-8 prose">
        <Content />
      </div>
    </div>
  </section>
</Layout>
