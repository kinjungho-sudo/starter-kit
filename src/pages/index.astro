---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allMissions = await getCollection('missions');
const allMembers  = await getCollection('members');
const allAnalysis = await getCollection('analysis');

// 연/월 그룹핑
function getYM(m: any): string {
  return m.data.date ? String(m.data.date).slice(0, 7) : '미분류';
}
const ymMap = allMissions.reduce((acc, m) => {
  const ym = getYM(m);
  if (!acc[ym]) acc[ym] = [];
  acc[ym].push(m);
  return acc;
}, {} as Record<string, typeof allMissions>);
const yearMonths = Object.keys(ymMap).sort((a, b) => b.localeCompare(a));
const latestYm = yearMonths[0] ?? null;
const latestMissions = latestYm ? (ymMap[latestYm] ?? []).sort((a,b) =>
  (a.data.member ?? '').localeCompare(b.data.member ?? '')) : [];
const latestAnalysis = [...allAnalysis].sort((a, b) =>
  (b.data.finished ?? '').localeCompare(a.data.finished ?? ''))[0] ?? null;
const totalSubmissions = allMissions.length;
---

<Layout title="대시보드">

  <div slot="sidebar">
    <p class="sb-label">아카이브</p>
    {yearMonths.map(ym => {
      const [y, mo] = ym.split('-');
      const label = ym === '미분류' ? '미분류' : `${y}년 ${Number(mo)}월`;
      return (
        <a href={`/archive?ym=${ym}`} class={`sb-item${ym === latestYm ? ' active' : ''}`}>
          <span class="sb-dot"></span>
          {label}
          <span class="count">{ymMap[ym].length}</span>
        </a>
      );
    })}
    {yearMonths.length === 0 && <p style="padding:4px 12px; font-size:11px; color:var(--muted2)">아직 없음</p>}

    <hr class="sb-divider" />

    <p class="sb-label">멤버</p>
    {allMembers.map(m => (
      <a href={`/team/${m.id}`} class="sb-item">
        {m.data.nickname ?? m.id}
        <span class="count">{m.data.role ?? ''}</span>
      </a>
    ))}
  </div>

  <!-- stat 행 -->
  <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:24px;">
    <div class="stat">
      <div class="stat-value">{latestYm ? latestYm.slice(5) + '월' : '—'}</div>
      <div class="stat-label">최신 월</div>
    </div>
    <div class="stat">
      <div class="stat-value">{latestMissions.length}</div>
      <div class="stat-label">이번 주 제출</div>
    </div>
    <div class="stat">
      <div class="stat-value">{allMembers.length}</div>
      <div class="stat-label">전체 멤버</div>
    </div>
  </div>

  <!-- 페이지 헤더 -->
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
    <p class="section-label">
      {latestYm ? (() => { const [y,mo]=latestYm.split('-'); return `${y}년 ${Number(mo)}월 제출물`; })() : '제출물'}
    </p>
    {latestYm && (
      <a href={`/archive?ym=${latestYm}`} style="font-size:11px; color:var(--accent); text-decoration:none;">전체 보기 →</a>
    )}
  </div>

  <!-- 제출물 카드 -->
  {latestMissions.length > 0 ? (
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:8px; margin-bottom:28px;">
      {latestMissions.map(m => (
        <a href={`/archive/${m.id}`} class="card">
          <p class="card-label">{m.data.member ?? m.id}</p>
          <p class="card-title">{m.data.title ?? m.id}</p>
          {m.data.stack && m.data.stack.length > 0 && (
            <div style="display:flex; flex-wrap:wrap; gap:4px; margin-top:8px;">
              {(m.data.stack as string[]).slice(0,3).map(t => (
                <span class="badge badge-indigo">{t}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  ) : (
    <div style="padding:48px 0; text-align:center; color:var(--muted2); font-size:13px;">
      아직 제출된 과제가 없습니다.
    </div>
  )}

  <!-- 최신 독서 노트 -->
  {latestAnalysis && (
    <>
      <p class="section-label" style="margin-top:8px;">최근 독서</p>
      <a href={`/analysis/${latestAnalysis.id}`} class="row" style="border-radius:6px; border:1px solid var(--border);">
        <span class="badge badge-indigo">독서</span>
        <span style="font-size:12px; color:var(--text); flex:1;">
          {latestAnalysis.data.title ?? ''}
          {latestAnalysis.data.author ? ` · ${latestAnalysis.data.author}` : ''}
        </span>
        {latestAnalysis.data.finished && (
          <span style="font-size:11px; color:var(--muted2);">{latestAnalysis.data.finished}</span>
        )}
        <span style="margin-left:auto; font-size:11px; color:var(--accent);">→</span>
      </a>
    </>
  )}

</Layout>
