---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allMissions = await getCollection('missions');
const allMembers  = await getCollection('members');
const allAnalysis = await getCollection('analysis');

const weeks = [...new Set(allMissions.map(m => m.data.week ?? 0))].sort((a,b) => b - a);
const latestWeek = weeks[0] ?? null;
const latestMissions = latestWeek != null
  ? allMissions.filter(m => m.data.week === latestWeek).sort((a,b) =>
      (a.data.member ?? '').localeCompare(b.data.member ?? ''))
  : [];
const latestAnalysis = [...allAnalysis].sort((a,b) => (b.data.week ?? 0) - (a.data.week ?? 0))[0] ?? null;
const totalSubmissions = allMissions.length;
---

<Layout title="대시보드">

  <div slot="sidebar">
    <p class="sb-label">주차</p>
    {weeks.map(w => (
      <a href={`/archive?week=${w}`} class={`sb-item${w === latestWeek ? ' active' : ''}`}>
        <span class="sb-dot"></span>
        Week {String(w).padStart(2,'0')}
        <span class="count">{allMissions.filter(m => m.data.week === w).length}</span>
      </a>
    ))}
    {weeks.length === 0 && <p style="padding:4px 12px; font-size:11px; color:var(--muted2)">아직 없음</p>}

    <hr class="sb-divider" />

    <p class="sb-label">멤버</p>
    {allMembers.map(m => (
      <a href={`/team/${m.id}`} class="sb-item">
        {m.data.nickname ?? m.id}
        <span class="count">{m.data.role ?? ''}</span>
      </a>
    ))}
  </div>

  <!-- stat 행 -->
  <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:24px;">
    <div class="stat">
      <div class="stat-value">{latestWeek != null ? `W${String(latestWeek).padStart(2,'0')}` : '—'}</div>
      <div class="stat-label">현재 주차</div>
    </div>
    <div class="stat">
      <div class="stat-value">{latestMissions.length}</div>
      <div class="stat-label">이번 주 제출</div>
    </div>
    <div class="stat">
      <div class="stat-value">{allMembers.length}</div>
      <div class="stat-label">전체 멤버</div>
    </div>
  </div>

  <!-- 페이지 헤더 -->
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:12px;">
    <p class="section-label">
      {latestWeek != null ? `Week ${String(latestWeek).padStart(2,'0')} 제출물` : '제출물'}
    </p>
    {latestWeek != null && (
      <a href="/archive" style="font-size:11px; color:var(--accent); text-decoration:none;">전체 보기 →</a>
    )}
  </div>

  <!-- 제출물 카드 -->
  {latestMissions.length > 0 ? (
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:8px; margin-bottom:28px;">
      {latestMissions.map(m => (
        <a href={`/archive/${m.id}`} class="card">
          <p class="card-label">{m.data.member ?? m.id}</p>
          <p class="card-title">{m.data.title ?? m.id}</p>
          {m.data.stack && m.data.stack.length > 0 && (
            <div style="display:flex; flex-wrap:wrap; gap:4px; margin-top:8px;">
              {(m.data.stack as string[]).slice(0,3).map(t => (
                <span class="badge badge-indigo">{t}</span>
              ))}
            </div>
          )}
        </a>
      ))}
    </div>
  ) : (
    <div style="padding:48px 0; text-align:center; color:var(--muted2); font-size:13px;">
      아직 제출된 과제가 없습니다.
    </div>
  )}

  <!-- 최신 분석 -->
  {latestAnalysis && (
    <>
      <p class="section-label" style="margin-top:8px;">최신 분석</p>
      <a href={`/analysis/${latestAnalysis.id}`} class="row" style="border-radius:6px; border:1px solid var(--border);">
        <span class="badge badge-indigo">W{String(latestAnalysis.data.week ?? '').padStart(2,'0')}</span>
        <span style="font-size:12px; color:var(--text);">
          {latestAnalysis.data.total_submissions != null ? `${latestAnalysis.data.total_submissions}명 제출` : ''}
          {latestAnalysis.data.date ? ` · ${latestAnalysis.data.date}` : ''}
        </span>
        <span style="margin-left:auto; font-size:11px; color:var(--accent);">→</span>
      </a>
    </>
  )}

</Layout>
