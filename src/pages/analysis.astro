---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('analysis');
const sorted = [...all].sort((a,b) => (b.data.week ?? 0) - (a.data.week ?? 0));
---

<Layout title="분석">

  <div slot="sidebar">
    <p class="sb-label">리포트</p>
    {sorted.map(r => (
      <a href={`/analysis/${r.slug}`} class="sb-item">
        <span class="sb-dot"></span>
        Week {String(r.data.week ?? '').padStart(2,'0')}
        <span class="count">{r.data.total_submissions ?? 0}명</span>
      </a>
    ))}
    {sorted.length === 0 && <p style="padding:4px 12px; font-size:11px; color:var(--muted2)">아직 없음</p>}
  </div>

  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div>
      <h1 class="page-title">분석 리포트</h1>
      <p class="page-meta">AI 주간 분석 {sorted.length}건</p>
    </div>
  </div>

  {sorted.length === 0 ? (
    <div style="padding:64px 0; text-align:center; color:var(--muted2); font-size:13px;">
      <code style="color:var(--accent); opacity:0.6;">/analyze N</code> 을 실행하면 자동 생성됩니다.
    </div>
  ) : (
    <div style="display:flex; flex-direction:column; gap:2px;">
      {sorted.map(r => (
        <a href={`/analysis/${r.slug}`} class="row">
          <span class="badge badge-indigo">W{String(r.data.week ?? '').padStart(2,'0')}</span>
          <span style="font-size:12px; color:var(--text); flex:1;">Week {r.data.week} 분석 리포트</span>
          <span style="font-size:11px; color:var(--muted2);">{r.data.total_submissions ?? 0}명 · {r.data.date ?? ''}</span>
          <span style="font-size:11px; color:var(--accent);">→</span>
        </a>
      ))}
    </div>
  )}

</Layout>
