---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allAnalysis = await getCollection('analysis');
const sorted = allAnalysis.sort((a, b) => b.data.week - a.data.week);
---

<Layout title="분석">
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12">
        <div class="text-xs font-black uppercase tracking-widest text-indigo-400 mb-3">ANALYSIS</div>
        <h1 class="text-3xl font-black text-white mb-3">AI 주간 분석 리포트</h1>
        <p class="text-white/50">매주 과제를 AI가 분석해 트렌드와 인사이트를 도출합니다.</p>
      </div>

      {sorted.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-white/30 text-sm mb-2">아직 분석 리포트가 없습니다.</p>
          <p class="text-white/20 text-xs">
            <code class="bg-white/10 px-2 py-0.5 rounded">/analyze N</code> 명령어를 실행하면 자동 생성됩니다.
          </p>
        </div>
      ) : (
        <div class="space-y-6">
          {sorted.map(report => (
            <a href={`/analysis/${report.id}`}
              class="group block bg-white/[0.04] border border-white/10 hover:border-indigo-400/30 rounded-2xl p-8 transition-colors">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-xs font-black uppercase tracking-widest text-indigo-400 border border-indigo-400/30 rounded-full px-3 py-1">
                  WEEK {report.data.week}
                </span>
                <span class="text-xs text-white/30">
                  {report.data.date}
                  {report.data.total_submissions && ` · ${report.data.total_submissions}건 제출`}
                </span>
              </div>
              <div class="flex flex-wrap gap-2 mt-2">
                {(report.data.tags ?? []).filter((t: string) => t !== '주차분석').map((tag: string) => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-indigo-500/10 text-indigo-300 border border-indigo-400/20">{tag}</span>
                ))}
              </div>
              <div class="text-xs text-indigo-400/60 mt-4 group-hover:text-indigo-400 transition-colors">리포트 보기 →</div>
            </a>
          ))}
        </div>
      )}

      <div class="mt-12 text-center text-white/30 text-sm">
        분석 리포트는 <code class="text-white/50 bg-white/10 px-2 py-0.5 rounded">/analyze N</code>으로 자동 생성됩니다.
      </div>
    </div>
  </section>
</Layout>
