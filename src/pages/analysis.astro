---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('analysis');
const sorted = [...all].sort((a, b) =>
  (b.data.finished ?? '').localeCompare(a.data.finished ?? '')
);

const tags = [...new Set(sorted.flatMap(b => b.data.tags ?? []))].sort();
const filterTag = Astro.url.searchParams.get('tag') ?? '';
const filtered = filterTag ? sorted.filter(b => b.data.tags?.includes(filterTag)) : sorted;
---

<Layout title="독서 노트" activeTab="analysis">

  <div slot="sidebar">
    <p class="sb-label">전체</p>
    <a href="/analysis" class={`sb-item${!filterTag ? ' active' : ''}`}>
      모든 책
      <span class="count">{sorted.length}</span>
    </a>

    {tags.length > 0 && (
      <>
        <hr class="sb-divider" />
        <p class="sb-label">태그</p>
        {tags.map(t => (
          <a href={`/analysis?tag=${encodeURIComponent(t)}`} class={`sb-item${filterTag === t ? ' active' : ''}`}>
            {t}
            <span class="count">{sorted.filter(b => b.data.tags?.includes(t)).length}</span>
          </a>
        ))}
      </>
    )}
  </div>

  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div>
      <h1 class="page-title">독서 노트</h1>
      <p class="page-meta">{filtered.length}권</p>
    </div>
  </div>

  {filtered.length === 0 ? (
    <div style="padding:64px 0; text-align:center; color:var(--muted2); font-size:13px;">아직 등록된 독서 노트가 없습니다.</div>
  ) : (
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:8px;">
      {filtered.map(book => (
        <a href={`/analysis/${book.id}`} class="card">
          {book.data.tags && book.data.tags.length > 0 && (
            <p class="card-label">{book.data.tags[0]}</p>
          )}
          <p class="card-title">{book.data.title}</p>
          <p class="card-meta">{book.data.author}</p>
          {book.data.finished && (
            <p style="font-size:10px; color:var(--muted2); margin-top:8px;">완독 {book.data.finished}</p>
          )}
        </a>
      ))}
    </div>
  )}

</Layout>
