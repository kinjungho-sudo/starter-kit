---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allMissions = await getCollection('missions');
  const weeks = [...new Set(allMissions.map(m => m.data.week))];
  return weeks.map(weekNum => ({
    params: { week: `week-${String(weekNum).padStart(2, '0')}` },
    props: { weekNum },
  }));
}

const { weekNum } = Astro.props;
const allMissions = await getCollection('missions');
const missions = allMissions
  .filter(m => m.data.week === weekNum)
  .sort((a, b) => a.data.member.localeCompare(b.data.member));

// 렌더링된 콘텐츠 미리 준비
const rendered = await Promise.all(
  missions.map(async m => ({ id: m.id, member: m.data.member, Content: (await render(m)).Content }))
);
---

<Layout title={`Week ${weekNum} 아카이브`}>
  <section class="py-16 px-6">
    <div class="max-w-3xl mx-auto">
      <div class="mb-10">
        <a href="/archive" class="text-xs text-white/40 hover:text-white/70 transition-colors mb-4 inline-block">← 아카이브 목록</a>
        <div class="text-xs font-black uppercase tracking-widest text-indigo-400 mb-2">WEEK {weekNum}</div>
        <h1 class="text-3xl font-black text-white">Week {weekNum} 과제</h1>
        <p class="text-white/40 text-sm mt-1">{missions.length}명 제출</p>
      </div>

      {missions.length === 0 ? (
        <p class="text-white/30 text-sm">이 주차에 제출된 과제가 없습니다.</p>
      ) : (
        <div class="space-y-12">
          {missions.map((mission, i) => {
            const { Content } = rendered[i];
            return (
              <div id={mission.data.member} class="scroll-mt-20">
                <div class="flex items-start justify-between gap-4 mb-4">
                  <div>
                    <span class="text-xs font-black text-indigo-400 uppercase tracking-widest">{mission.data.member}</span>
                    <h2 class="text-xl font-black text-white mt-1">{mission.data.title}</h2>
                  </div>
                  {mission.data.url && (
                    <a href={mission.data.url} target="_blank" rel="noopener noreferrer"
                      class="shrink-0 text-xs text-indigo-400 border border-indigo-400/30 hover:border-indigo-400 rounded-lg px-3 py-1.5 transition-colors">
                      결과물 →
                    </a>
                  )}
                </div>

                {(mission.data.stack ?? []).length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-5">
                    {(mission.data.stack ?? []).map((s: string) => (
                      <span class="text-xs px-2.5 py-0.5 rounded-full bg-white/[0.06] text-white/60 border border-white/10">{s}</span>
                    ))}
                  </div>
                )}

                <div class="prose">
                  <Content />
                </div>

                {i < missions.length - 1 && (
                  <div class="border-b border-white/10 mt-10"></div>
                )}
              </div>
            );
          })}
        </div>
      )}
    </div>
  </section>
</Layout>
