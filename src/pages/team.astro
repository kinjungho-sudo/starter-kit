---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('members');
const sorted = [...all].sort((a,b) => {
  const aOp = (a.data.role ?? '').includes('운영자');
  const bOp = (b.data.role ?? '').includes('운영자');
  if (aOp && !bOp) return -1;
  if (!aOp && bOp) return 1;
  return (a.data.nickname ?? '').localeCompare(b.data.nickname ?? '');
});
---

<Layout title="팀">

  <div slot="sidebar">
    <p class="sb-label">멤버</p>
    {sorted.map(m => (
      <a href={`/team/${m.slug}`} class="sb-item">
        {m.data.nickname ?? m.slug}
        <span class="count">{m.data.role ?? ''}</span>
      </a>
    ))}
  </div>

  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div>
      <h1 class="page-title">팀</h1>
      <p class="page-meta">Comind Works {sorted.length}명</p>
    </div>
  </div>

  {sorted.length === 0 ? (
    <div style="padding:64px 0; text-align:center; color:var(--muted2); font-size:13px;">멤버 정보가 없습니다.</div>
  ) : (
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:8px;">
      {sorted.map(m => (
        <a href={`/team/${m.slug}`} class="card">
          <p class="card-label">{m.data.role ?? 'Builder'}</p>
          <p class="card-title">{m.data.nickname ?? m.slug}</p>
          {m.data.github && <p class="card-meta">@{m.data.github}</p>}
          {m.data.joined && (
            <p style="font-size:10px; color:var(--muted2); margin-top:8px;">참여 {m.data.joined}</p>
          )}
        </a>
      ))}
    </div>
  )}

</Layout>
