---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

let all: any[] = [];
try { all = await getCollection('insights'); } catch { all = await getCollection('skills'); }

const categories = [...new Set(all.map((s:any) => s.data.category).filter(Boolean))].sort();
const filterCat = Astro.url.searchParams.get('cat') ?? '';
const filtered = filterCat ? all.filter((s:any) => s.data.category === filterCat) : all;
---

<Layout title="인사이트">

  <div slot="sidebar">
    <p class="sb-label">전체</p>
    <a href="/insights" class={`sb-item${!filterCat ? ' active' : ''}`}>
      모든 인사이트
      <span class="count">{all.length}</span>
    </a>

    {categories.length > 0 && (
      <>
        <hr class="sb-divider" />
        <p class="sb-label">카테고리</p>
        {categories.map((cat: string) => (
          <a href={`/insights?cat=${encodeURIComponent(cat)}`} class={`sb-item${filterCat === cat ? ' active' : ''}`}>
            {cat}
            <span class="count">{all.filter((s:any) => s.data.category === cat).length}</span>
          </a>
        ))}
      </>
    )}
  </div>

  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <div>
      <h1 class="page-title">{filterCat ? filterCat : '인사이트'}</h1>
      <p class="page-meta">{filtered.length}건</p>
    </div>
  </div>

  {filtered.length === 0 ? (
    <div style="padding:64px 0; text-align:center; color:var(--muted2); font-size:13px;">아직 등록된 인사이트가 없습니다.</div>
  ) : (
    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:8px;">
      {filtered.map((s:any) => (
        <a href={`/insights/${s.id}`} class="card">
          {(s.data.category || s.data.keywords?.length) && (
            <p class="card-label">{s.data.category ?? (s.data.keywords ?? []).join(' · ')}</p>
          )}
          <p class="card-title">{s.data.title ?? s.id}</p>
          {s.data.summary && (
            <p class="card-meta" style="display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
              {s.data.summary}
            </p>
          )}
        </a>
      ))}
    </div>
  )}

</Layout>
