---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

let all: any[] = [];
try { all = await getCollection('insights'); } catch { all = []; }

const normalized = all.map((s: any) => ({
  ...s,
  data: { ...s.data, category: s.data.category ?? '기타' }
}));

const categories = ['전체', ...([...new Set(normalized.map((s:any) => s.data.category))].sort())];
---

<Layout title="인사이트">

  <div slot="sidebar">
    <p class="sb-label">카테고리</p>
    {categories.map((cat) => (
      <button class="sb-item" data-cat={cat}
        style="background:none; border:none; width:100%; text-align:left; cursor:pointer;">
        {cat}
        <span class="count">
          {cat === '전체' ? normalized.length : normalized.filter((s:any) => s.data.category === cat).length}
        </span>
      </button>
    ))}
  </div>

  <!-- 헤더 -->
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
    <div>
      <h1 class="page-title" id="page-heading">인사이트</h1>
      <p class="page-meta" id="page-count">{normalized.length}건</p>
    </div>
    <div style="position:relative;">
      <input id="search-input" type="text" placeholder="제목 검색..."
        style="height:28px; padding:0 10px 0 28px; background:var(--surface); border:1px solid var(--border); border-radius:6px; color:var(--text); font-size:12px; width:180px; outline:none;"
        onfocus="this.style.borderColor='var(--accent)'"
        onblur="this.style.borderColor='var(--border)'" />
      <span style="position:absolute; left:8px; top:50%; transform:translateY(-50%); color:var(--muted2); font-size:12px; pointer-events:none;">⌕</span>
    </div>
  </div>

  <!-- 콘텐츠 -->
  <div id="insights-container">
    {categories.filter(c => c !== '전체').map((cat) => (
      <div class="cat-section" data-section={cat}>
        <p class="section-label" style="margin-bottom:6px;">
          {cat} <span style="font-weight:400; opacity:0.5;">({normalized.filter((s:any) => s.data.category === cat).length})</span>
        </p>
        <div style="display:flex; flex-direction:column; gap:1px; margin-bottom:20px;">
          {normalized.filter((s:any) => s.data.category === cat).map((s:any) => (
            <a href={`/insights/${s.id}`}
               class="row insight-row"
               data-slug={s.id}
               data-title={(s.data.title ?? s.id).toLowerCase()}
               data-cat={s.data.category}>
              <span class="badge badge-indigo" style="flex-shrink:0;">{s.data.category}</span>
              <span style="font-size:12px; color:var(--text); flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                {s.data.title ?? s.id}
              </span>
              <span style="display:flex; align-items:center; gap:10px; flex-shrink:0;">
                {s.data.created && (
                  <span style="font-size:10px; color:var(--muted2);">
                    {String(s.data.created).slice(0,10)}
                  </span>
                )}
                <span class="view-count" data-slug={s.id}
                  style="font-size:10px; color:var(--muted2); display:flex; align-items:center; gap:3px; min-width:36px;">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  <span class="view-num">—</span>
                </span>
              </span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div id="empty-state" style="display:none; padding:64px 0; text-align:center; color:var(--muted2); font-size:13px;">
    검색 결과가 없습니다.
  </div>

</Layout>

<script>
  // ── 탭 / 검색 필터 ──────────────────────────────
  const catButtons  = document.querySelectorAll<HTMLButtonElement>('[data-cat]');
  const sections    = document.querySelectorAll<HTMLElement>('.cat-section');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const heading     = document.getElementById('page-heading')!;
  const countEl     = document.getElementById('page-count')!;
  const emptyState  = document.getElementById('empty-state')!;

  let activeCat   = '전체';
  let searchQuery = '';

  function render() {
    let visible = 0;
    sections.forEach(sec => {
      const inCat = activeCat === '전체' || sec.dataset.section === activeCat;
      const label = sec.querySelector<HTMLElement>('.section-label');
      if (label) label.style.display = activeCat === '전체' ? '' : 'none';

      const rows = sec.querySelectorAll<HTMLElement>('.insight-row');
      let secVis = 0;
      rows.forEach(row => {
        const match = !searchQuery || (row.dataset.title ?? '').includes(searchQuery);
        row.style.display = (inCat && match) ? '' : 'none';
        if (inCat && match) secVis++;
      });
      sec.style.display = secVis > 0 ? '' : 'none';
      visible += secVis;
    });

    heading.textContent = activeCat === '전체' ? '인사이트' : activeCat;
    countEl.textContent = `${visible}건`;
    emptyState.style.display = visible === 0 ? '' : 'none';
    catButtons.forEach(btn => btn.classList.toggle('active', btn.dataset.cat === activeCat));
  }

  catButtons.forEach(btn => btn.addEventListener('click', () => {
    activeCat = btn.dataset.cat ?? '전체';
    render();
  }));
  searchInput.addEventListener('input', () => {
    searchQuery = searchInput.value.toLowerCase().trim();
    render();
  });

  // ── Supabase 설정 ──────────────────────────────
  const SUPABASE_URL = import.meta.env.VITE_SUPABASE_URL as string;
  const SUPABASE_KEY = import.meta.env.VITE_SUPABASE_ANON_KEY as string;

  // ── 조회수 일괄 로드 ───────────────────────────
  async function loadViews() {
    try {
      const res = await fetch(`${SUPABASE_URL}/rest/v1/views?select=slug,count`, {
        headers: {
          apikey: SUPABASE_KEY,
          Authorization: `Bearer ${SUPABASE_KEY}`,
        }
      });
      const data: { slug: string; count: number }[] = await res.json();
      const map = new Map(data.map(d => [d.slug, d.count]));

      document.querySelectorAll<HTMLElement>('.view-count').forEach(el => {
        const slug = el.dataset.slug ?? '';
        const numEl = el.querySelector<HTMLElement>('.view-num');
        if (numEl) numEl.textContent = String(map.get(slug) ?? 0);
      });
    } catch {}
  }

  // ── 클릭 시 조회수 +1 (upsert) ────────────────
  document.querySelectorAll<HTMLAnchorElement>('.insight-row').forEach(row => {
    row.addEventListener('click', () => {
      const slug = row.dataset.slug;
      if (!slug) return;
      // 비동기로 카운트 증가 (네비게이션 막지 않음)
      fetch(`${SUPABASE_URL}/rest/v1/rpc/increment_view`, {
        method: 'POST',
        headers: {
          apikey: SUPABASE_KEY,
          Authorization: `Bearer ${SUPABASE_KEY}`,
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ p_slug: slug }),
      }).catch(() => {});
    });
  });

  loadViews();
</script>
