---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allInsights = await getCollection('insights');
const sorted = allInsights.sort((a, b) => (b.data.week ?? 0) - (a.data.week ?? 0));
---

<Layout title="인사이트">
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12">
        <div class="text-xs font-black uppercase tracking-widest text-indigo-400 mb-3">INSIGHTS</div>
        <h1 class="text-3xl font-black text-white mb-3">스킬 & 인사이트</h1>
        <p class="text-white/50">멤버들이 직접 발견한 도구, 기법, 배움을 공유합니다.</p>
      </div>

      {sorted.length === 0 ? (
        <div class="text-center py-20">
          <p class="text-white/30 text-sm mb-2">아직 등록된 인사이트가 없습니다.</p>
          <p class="text-white/20 text-xs">
            <code class="bg-white/10 px-2 py-0.5 rounded">02_skill_insight/</code> 폴더에 마크다운 파일을 추가하면 자동 반영됩니다.
          </p>
        </div>
      ) : (
        <div class="space-y-6">
          {sorted.map(item => (
            <a href={`/insights/${item.id}`}
              class="group block bg-white/[0.04] border border-white/10 hover:border-indigo-400/30 rounded-2xl p-6 transition-colors">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-bold text-indigo-400">{item.data.author}</span>
                {item.data.week && <span class="text-xs text-white/30">Week {item.data.week}</span>}
              </div>
              <h2 class="font-bold text-white text-lg mb-2 leading-snug group-hover:text-indigo-200 transition-colors">
                {item.data.title}
              </h2>
              {item.data.summary && (
                <p class="text-sm text-white/60 mb-4 leading-relaxed">{item.data.summary}</p>
              )}
              <div class="flex flex-wrap gap-2">
                {(item.data.tags ?? []).map((tag: string) => (
                  <span class="text-xs px-2.5 py-0.5 rounded-full bg-white/[0.06] text-white/60 border border-white/10">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      )}

      <div class="mt-12 text-center text-white/30 text-sm">
        인사이트는 <code class="text-white/50 bg-white/10 px-2 py-0.5 rounded">02_skill_insight/</code> 폴더에 마크다운으로 작성하면 자동 반영됩니다.
      </div>
    </div>
  </section>
</Layout>
