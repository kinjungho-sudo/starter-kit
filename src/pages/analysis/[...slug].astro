---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const analyses = await getCollection('analysis');
  return analyses.map(entry => ({ params: { slug: entry.slug }, props: { entry } }));
}
const { entry } = Astro.props;
const { Content } = await entry.render();
---
<Layout title={`Week ${entry.data.week} 분석`} activeTab="analysis">

  <div slot="sidebar">
    <div class="sidebar-section">
      <a href="/analysis" class="sidebar-link">← 분석 목록</a>
    </div>
    <div class="sidebar-section">
      <p class="sidebar-label">정보</p>
      <p style="padding: 4px 1rem; font-size: 12px; color: var(--muted);">Week {entry.data.week}</p>
      {entry.data.date && <p style="padding: 4px 1rem; font-size: 12px; color: var(--muted);">{entry.data.date}</p>}
      {entry.data.total_submissions != null && (
        <p style="padding: 4px 1rem; font-size: 12px; color: var(--muted);">{entry.data.total_submissions}명 제출</p>
      )}
    </div>
  </div>

  <div class="page-header">
    <p class="card-label">Week {entry.data.week} · {entry.data.date}</p>
    <h1>Week {entry.data.week} 분석 리포트</h1>
  </div>
  <article style="line-height: 1.8; font-size: 15px; color: rgba(255,255,255,0.82); max-width: 680px;">
    <Content />
  </article>

</Layout>
