---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('gallery');
  return items.map(entry => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const typeLabel: Record<string, string> = {
  vanilla: '🎨 Vanilla HTML',
  ppt: '📊 PPT',
  external: '🔗 외부 링크',
};

const isEmbed = entry.data.type === 'vanilla' || entry.data.type === 'ppt';
---

<Layout title={entry.data.title ?? entry.id}>
  <section class="py-12 px-6">
    <div class="max-w-5xl mx-auto">

      <!-- 브레드크럼 -->
      <div class="flex items-center gap-2 mb-8 text-sm text-white/40">
        <a href="/gallery" class="hover:text-white transition-colors">갤러리</a>
        {entry.data.type && (
          <>
            <span>·</span>
            <span>{typeLabel[entry.data.type] ?? entry.data.type}</span>
          </>
        )}
      </div>

      <!-- 헤더 -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-3 flex-wrap">
          {entry.data.type && (
            <span class="text-xs font-bold px-2.5 py-1 rounded-full border border-indigo-500/40 text-indigo-400 bg-indigo-500/10">
              {typeLabel[entry.data.type] ?? entry.data.type}
            </span>
          )}
          {entry.data.created && (
            <span class="text-xs text-white/30">{entry.data.created}</span>
          )}
          {entry.data.link && (
            <a href={entry.data.link} target="_blank" rel="noopener"
               class="ml-auto text-xs text-indigo-400 hover:text-indigo-300 transition-colors">
              ↗ 새 탭에서 열기
            </a>
          )}
        </div>
        <h1 class="text-2xl font-black text-white mb-2">{entry.data.title ?? entry.id}</h1>
        {entry.data.description && (
          <p class="text-white/60 text-sm">{entry.data.description}</p>
        )}
        {entry.data.maker && (
          <p class="text-white/40 text-xs mt-2">by {entry.data.maker}</p>
        )}
        {entry.data.tags && entry.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {entry.data.tags.map((tag: string) => (
              <span class="text-xs px-2.5 py-1 rounded-full bg-white/[0.06] text-white/60 border border-white/10">
                {tag}
              </span>
            ))}
          </div>
        )}

        {(entry.data.agents?.length || entry.data.skills?.length || entry.data.features?.length) && (
          <div class="mt-6 p-4 rounded-2xl border border-white/10 bg-white/[0.02] space-y-3">
            {entry.data.agents?.length && (
              <div>
                <div class="text-[10px] font-black tracking-widest uppercase text-emerald-400 mb-2">AI 에이전트</div>
                <div class="flex flex-wrap gap-2">
                  {entry.data.agents.map((a: string) => (
                    <span class="text-xs px-2.5 py-1 rounded-full bg-emerald-500/10 text-emerald-300 border border-emerald-500/25">{a}</span>
                  ))}
                </div>
              </div>
            )}
            {entry.data.skills?.length && (
              <div>
                <div class="text-[10px] font-black tracking-widest uppercase text-amber-400 mb-2">Skills</div>
                <div class="flex flex-wrap gap-2">
                  {entry.data.skills.map((s: string) => (
                    <span class="text-xs px-2.5 py-1 rounded-full bg-amber-500/10 text-amber-300 border border-amber-500/25">{s}</span>
                  ))}
                </div>
              </div>
            )}
            {entry.data.features?.length && (
              <div>
                <div class="text-[10px] font-black tracking-widest uppercase text-indigo-400 mb-2">사용 기능</div>
                <div class="flex flex-wrap gap-2">
                  {entry.data.features.map((f: string) => (
                    <span class="text-xs px-2.5 py-1 rounded-full bg-indigo-500/10 text-indigo-300 border border-indigo-500/25">{f}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}
      </div>

      <!-- 임베드 or 외부 링크 -->
      {isEmbed && entry.data.link ? (
        <div class="w-full aspect-video border border-white/10 rounded-2xl overflow-hidden bg-black mb-8">
          <iframe
            src={entry.data.link}
            title={entry.data.title ?? entry.id}
            class="w-full h-full"
            allowfullscreen
          ></iframe>
        </div>
      ) : entry.data.link ? (
        <div class="mb-8">
          <a href={entry.data.link} target="_blank" rel="noopener"
             class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-bold text-sm transition-colors">
            ↗ 결과물 열기
          </a>
        </div>
      ) : null}

      <!-- 본문 설명 -->
      {entry.body && entry.body.trim() && (
        <div class="pt-8 border-t border-white/10">
          <article class="wiki-prose">
            <Content />
          </article>
        </div>
      )}

      <!-- 뒤로 -->
      <div class="mt-12 pt-8 border-t border-white/10">
        <a href="/gallery" class="text-sm text-white/40 hover:text-white transition-colors">
          ← 갤러리 목록으로
        </a>
      </div>

    </div>
  </section>
</Layout>

<style>
  .wiki-prose {
    color: rgba(255,255,255,0.75);
    line-height: 1.8;
    font-size: 15px;
  }
  .wiki-prose :global(h2) {
    font-size: 1.1rem;
    font-weight: 800;
    color: #fff;
    margin: 2rem 0 0.75rem;
  }
  .wiki-prose :global(p) { margin-bottom: 1rem; }
  .wiki-prose :global(ul) { padding-left: 1.5rem; margin-bottom: 1rem; }
  .wiki-prose :global(li) { margin-bottom: 0.3rem; }
  .wiki-prose :global(a) { color: #818cf8; }
  .wiki-prose :global(strong) { color: #fff; font-weight: 700; }
</style>
